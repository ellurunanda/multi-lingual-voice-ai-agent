# Application
APP_NAME=VoiceAI-Clinical-Agent
APP_ENV=development
APP_PORT=8000
DEBUG=true

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# Database (PostgreSQL)
DATABASE_URL=postgresql://voiceai:voiceai_password@localhost:5432/voiceai_db
POSTGRES_USER=voiceai
POSTGRES_PASSWORD=voiceai_password
POSTGRES_DB=voiceai_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
SESSION_TTL=3600

# WebSocket
WS_HOST=0.0.0.0
WS_PORT=8001
WS_MAX_CONNECTIONS=100

# Frontend
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Latency Targets (ms)
TARGET_STT_LATENCY=120
TARGET_LLM_LATENCY=200
TARGET_TTS_LATENCY=100
TARGET_TOTAL_LATENCY=450

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Campaign Scheduler
CAMPAIGN_SCHEDULER_INTERVAL=60
REMINDER_HOURS_BEFORE=24

# Language Support
SUPPORTED_LANGUAGES=en,hi,ta,te
DEFAULT_LANGUAGE=en